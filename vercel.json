{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "trailingSlash": false,
  "cleanUrls": true,
  "redirects": [
    { "source": "/gratis-banplanerare-agility", "destination": "/banplanerare", "permanent": true },
    { "source": "/agility-bana-ritverktyg", "destination": "/banplanerare", "permanent": true },
    { "source": "/blogg/agility-kurs-nyb%C3%B6rjare", "destination": "/blogg/agility-kurs-nyborjare", "permanent": true },
    { "source": "/blogg/agility-kurs-nybörjare", "destination": "/blogg/agility-kurs-nyborjare", "permanent": true },
    { "source": "/agility-kurs-nyb%C3%B6rjare", "destination": "/blogg/agility-kurs-nyborjare", "permanent": true },
    { "source": "/agility-kurs-nybörjare", "destination": "/blogg/agility-kurs-nyborjare", "permanent": true },
    { "source": "/dashboard", "destination": "/v3", "permanent": false },
    { "source": "/stats", "destination": "/v3/stats", "permanent": false },
    { "source": "/training", "destination": "/v3/training", "permanent": false },
    { "source": "/course-planner", "destination": "/v3/course-planner-v2", "permanent": false },
    { "source": "/course-planner-beta", "destination": "/v3/course-planner-v2", "permanent": false },
    { "source": "/stopwatch", "destination": "/v3/stopwatch", "permanent": false },
    { "source": "/goals", "destination": "/v3/goals", "permanent": false },
    { "source": "/app/competition", "destination": "/v3/competition", "permanent": false },
    { "source": "/competition", "destination": "/v3/competition", "permanent": false },
    { "source": "/competition-calendar", "destination": "/v3/competition", "permanent": false },
    { "source": "/dogs", "destination": "/v3/dogs", "permanent": false },
    { "source": "/health", "destination": "/v3/health", "permanent": false },
    { "source": "/friends", "destination": "/v3/friends", "permanent": false },
    { "source": "/chat", "destination": "/v3/chat", "permanent": false },
    { "source": "/clubs", "destination": "/v3/clubs", "permanent": false },
    { "source": "/courses", "destination": "/v3/courses", "permanent": false },
    { "source": "/settings", "destination": "/v3/settings", "permanent": false },
    { "source": "/admin", "destination": "/v3/admin", "permanent": false },
    { "source": "/index", "destination": "/v3", "permanent": false },
    { "source": "/v2", "destination": "/v3", "permanent": false }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/|.*\\.(?:js|css|png|jpg|jpeg|svg|webp|ico|woff2?|ttf|eot|map|json|xml|txt|webmanifest|mp4|webm)).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(), geolocation=(self), interest-cohort=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|svg|webp|ico|woff2?|ttf|eot)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sitemap(.*)\\.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/blogg/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=31536000, must-revalidate" }
      ]
    },
    {
      "source": "/blogg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=31536000, must-revalidate" }
      ]
    }
  ]
}
